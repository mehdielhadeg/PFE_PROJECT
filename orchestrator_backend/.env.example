DJANGO_SECRET_KEY=change-me
DJANGO_DEBUG=1
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost
DJANGO_CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Single DB setting:
# - Leave empty to use local SQLite
# - Set to Supabase Postgres URL to use Supabase as Django DB
# IMPORTANT: URL-encode special characters in password (e.g. @ -> %40)
# Example:
# DATABASE_URL=postgresql://postgres.xxxxxxxxxxxxx:your_password%40with_special@aws-1-eu-west-1.pooler.supabase.com:6543/postgres?sslmode=require
DATABASE_URL=

INGESTION_SERVICE_URL=http://localhost:8001
INDEXING_SERVICE_URL=http://localhost:8002
LLM_SERVICE_URL=http://localhost:8003

# Supabase REST/Storage for conversations + metadata + files
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_KEY=your_service_role_key
SUPABASE_CONVERSATIONS_TABLE=conversation_sessions
SUPABASE_DOCUMENTS_TABLE=document_records
SUPABASE_BUCKET=rag-docs
