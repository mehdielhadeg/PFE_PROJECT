# Services environment
# Copy to services/.env and fill values.

PINECONE_API_KEY=
PINECONE_INDEX_NAME=rag
PINECONE_REGION=us-east-1
PINECONE_DIM=384
PINECONE_METRIC=cosine

HF_TOKEN=
HF_EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
HF_CHAT_MODEL=Qwen/Qwen2.5-7B-Instruct

SUPABASE_URL=
SUPABASE_KEY=
SUPABASE_BUCKET=rag-docs

INGESTION_SERVICE_URL=http://localhost:8001
INDEXING_SERVICE_URL=http://localhost:8002
LLM_SERVICE_URL=http://localhost:8003

# Debug retrieval (0 or 1)
RAG_DEBUG_RETRIEVAL=0

# Retrieval tuning
RAG_RETRIEVAL_K=20
RAG_MAX_CONTEXT_CHUNKS=4
